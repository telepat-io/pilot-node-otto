# Copy to .env and fill in. Used by compose.yaml (production) at deploy time.
# The smoke test (compose.smoke.yaml) needs nothing here (it ships safe defaults).

# ── Otto relay (required in prod) ─────────────────────────────────────────────
# JWT signing secret for relay-issued tokens. The relay code default is the
# literal 'dev-only-change-me' — you MUST set a strong value in production.
OTTO_TOKEN_SECRET=change-me-to-a-long-random-string

# Host interface the relay's :8787 binds to. The operator's Chrome (with the otto
# extension) pairs against this. 127.0.0.1 keeps it local; set 0.0.0.0 to expose
# it (then secure it — anyone who can reach it can pair a browser node).
OTTO_RELAY_BIND=127.0.0.1

# ── Pilot overlay endpoints ───────────────────────────────────────────────────
# Where the provider daemon registers so callers can reach the node. Defaults to
# the real Pilot network. Point at a self-hosted rendezvous for a private deploy.
# Confirm the current Pilot registry/beacon with the Pilot team.
PILOT_REGISTRY=34.71.57.205:9000
PILOT_BEACON=34.71.57.205:9001

# ── Optional ──────────────────────────────────────────────────────────────────
# PILOT_HOSTNAME=otto-provider
# LOG_LEVEL=info
